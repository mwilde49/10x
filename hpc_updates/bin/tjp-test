#!/usr/bin/env bash
# tjp-test — smoke-test a TJP pipeline with subsampled/minimal data
# For RNA-seq pipelines: copies test FASTQs to scratch, generates a test config.
# For 10x pipelines: generates a test config pointing to pre-staged test data.
# Delegates to tjp-launch --dev for submission to the dev partition.
#
# Usage: tjp-test <pipeline> [--clean]
#
# Supported pipelines: psoma, bulkrnaseq, cellranger, spaceranger, xeniumranger
#
# Examples:
#   tjp-test psoma              # run psoma smoke test
#   tjp-test cellranger         # run cellranger smoke test
#   tjp-test psoma --clean      # wipe previous test data first

set -euo pipefail

# Source shared libraries
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

# ── Constants ────────────────────────────────────────────────────────────────
TEST_DATA_SRC="$REPO_ROOT/test_data/rnaseq"
TENX_TEST_DATA="$REPO_ROOT/test_data/10x"
SUPPORTED_PIPELINES=(psoma bulkrnaseq cellranger spaceranger xeniumranger)

# ── Usage ────────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
Usage: tjp-test <pipeline> [--clean]

Smoke-test a pipeline on the dev partition.

Pipelines: ${SUPPORTED_PIPELINES[*]}

Options:
  --clean   Wipe previous test data in scratch before copying
  --help    Show this help message

Workflow:
  1. tjp-test psoma              # submit smoke test
  2. squeue -u \$USER             # monitor job
  3. tjp-test-validate psoma     # validate outputs after completion
EOF
    exit "${1:-0}"
}

# ── Argument parsing ─────────────────────────────────────────────────────────
PIPELINE=""
CLEAN=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --clean)  CLEAN=true; shift ;;
        --help|-h) usage 0 ;;
        -*)       die "Unknown option: $1" ;;
        *)
            if [[ -z "$PIPELINE" ]]; then
                PIPELINE="$1"
            else
                die "Unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

[[ -z "$PIPELINE" ]] && usage 1

# ── Validate pipeline ────────────────────────────────────────────────────────
is_supported=false
for p in "${SUPPORTED_PIPELINES[@]}"; do
    [[ "$p" == "$PIPELINE" ]] && is_supported=true
done
$is_supported || die "Unsupported pipeline: $PIPELINE (supported: ${SUPPORTED_PIPELINES[*]})"

# ── Paths ────────────────────────────────────────────────────────────────────
SCRATCH_TEST_DIR="$SCRATCH_ROOT/pipelines/$PIPELINE/test_data"

hyperion_banner "SMOKE TEST"

# ── Clean if requested ────────────────────────────────────────────────────────
if $CLEAN && [[ -d "$SCRATCH_TEST_DIR" ]]; then
    info "Cleaning previous test data: $SCRATCH_TEST_DIR"
    rm -rf "$SCRATCH_TEST_DIR"
fi

mkdir -p "$SCRATCH_TEST_DIR"

# ── Pipeline-specific test setup ─────────────────────────────────────────────
TEST_CONFIG="$SCRATCH_TEST_DIR/config.yaml"

case "$PIPELINE" in
    psoma|bulkrnaseq)
        # RNA-seq pipelines: copy test FASTQs to scratch
        SCRATCH_FASTQ_DIR="$SCRATCH_TEST_DIR/fastq"
        SRC_FASTQ_DIR="$TEST_DATA_SRC/fastq"
        SRC_SAMPLES="$TEST_DATA_SRC/$PIPELINE/samples.txt"

        if [[ ! -d "$SRC_FASTQ_DIR" ]]; then
            die "Test FASTQ directory not found: $SRC_FASTQ_DIR
  Run subsample_from_real.sh first to generate test data."
        fi

        if [[ ! -f "$SRC_SAMPLES" ]]; then
            die "Samples file not found: $SRC_SAMPLES"
        fi

        shopt -s nullglob
        src_files=("$SRC_FASTQ_DIR"/*.fastq.gz)
        shopt -u nullglob
        if [[ ${#src_files[@]} -eq 0 ]]; then
            die "No .fastq.gz files found in $SRC_FASTQ_DIR
  Run subsample_from_real.sh first to generate test data."
        fi

        mkdir -p "$SCRATCH_FASTQ_DIR"

        if [[ "$PIPELINE" == "psoma" ]]; then
            for f in "$SRC_FASTQ_DIR"/*_1.fastq.gz "$SRC_FASTQ_DIR"/*_2.fastq.gz; do
                [[ -f "$f" ]] || continue
                dest="$SCRATCH_FASTQ_DIR/$(basename "$f")"
                if [[ ! -f "$dest" ]]; then
                    info "Copying $(basename "$f") to scratch..."
                    cp "$f" "$dest"
                fi
            done
        elif [[ "$PIPELINE" == "bulkrnaseq" ]]; then
            for f in "$SRC_FASTQ_DIR"/*_1.fastq.gz; do
                [[ -f "$f" ]] || continue
                base=$(basename "$f")
                newname="${base/_1.fastq.gz/_R1_001.fastq.gz}"
                dest="$SCRATCH_FASTQ_DIR/$newname"
                if [[ ! -f "$dest" ]]; then
                    info "Copying $base -> $newname"
                    cp "$f" "$dest"
                fi
            done
            for f in "$SRC_FASTQ_DIR"/*_2.fastq.gz; do
                [[ -f "$f" ]] || continue
                base=$(basename "$f")
                newname="${base/_2.fastq.gz/_R2_001.fastq.gz}"
                dest="$SCRATCH_FASTQ_DIR/$newname"
                if [[ ! -f "$dest" ]]; then
                    info "Copying $base -> $newname"
                    cp "$f" "$dest"
                fi
            done
        fi

        cp "$SRC_SAMPLES" "$SCRATCH_TEST_DIR/samples.txt"
        info "Samples file: $SCRATCH_TEST_DIR/samples.txt"

        if [[ "$PIPELINE" == "psoma" ]]; then
            cat > "$TEST_CONFIG" <<YAML
project_name: Psoma-Test-2samples
species: Human
paired_end: true
fastq_dir: $SCRATCH_FASTQ_DIR
samples_file: $SCRATCH_TEST_DIR/samples.txt
hisat2_index: /groups/tprice/pipelines/references/hisat2_index/gencode48
reference_gtf: /groups/tprice/pipelines/references/gencode.v48.primary_assembly.annotation.gtf
exclude_bed_file_path: /groups/tprice/pipelines/references/filter.bed
blacklist_bed_file_path: /groups/tprice/pipelines/references/blacklist.bed
read1_suffix: _1
read2_suffix: _2
headcrop: 10
leading: 3
trailing: 3
slidingwindow: "4:15"
minlen: 36
illuminaclip_params: "2:30:10:5:true"
strand_st: --rf
strand_hts: reverse
paired_hts: pos
fastqc_cores: 40
run_fastqc: true
run_rna_pipeline: true
YAML
        elif [[ "$PIPELINE" == "bulkrnaseq" ]]; then
            cat > "$TEST_CONFIG" <<YAML
project_name: BulkRNASeq-Test-2samples
species: Human
paired_end: true
fastq_dir: $SCRATCH_FASTQ_DIR
samples_file: $SCRATCH_TEST_DIR/samples.txt
star_index: /groups/tprice/pipelines/references/star_index
reference_gtf: /groups/tprice/pipelines/references/gencode.v48.primary_assembly.annotation.gtf
exclude_bed_file_path: /groups/tprice/pipelines/references/filter.bed
blacklist_bed_file_path: /groups/tprice/pipelines/references/blacklist.bed
read1_suffix: _R1_001
read2_suffix: _R2_001
clip5_num: 11
clip3_num: 5
strand_st: --rf
strand_hts: reverse
paired_hts: pos
fastqc_cores: 40
run_fastqc: true
run_rna_pipeline: true
YAML
        fi
        ;;

    cellranger)
        # Cell Ranger: point to pre-staged test data
        SCRATCH_FASTQ_DIR="$SCRATCH_TEST_DIR/fastq"
        SRC_10X_FASTQ="$TENX_TEST_DATA/cellranger/fastq"

        if [[ -d "$SRC_10X_FASTQ" ]]; then
            mkdir -p "$SCRATCH_FASTQ_DIR"
            rsync -a "$SRC_10X_FASTQ/" "$SCRATCH_FASTQ_DIR/"
            info "Copied Cell Ranger test FASTQs to scratch"
        else
            warn "Test FASTQs not found at $SRC_10X_FASTQ — using placeholder path."
            warn "Stage test data first, or the job will fail."
            SCRATCH_FASTQ_DIR="$SRC_10X_FASTQ"
        fi

        cat > "$TEST_CONFIG" <<YAML
sample_id: cellranger_test
sample_name: cellranger_test
fastq_dir: $SCRATCH_FASTQ_DIR
transcriptome: /groups/tprice/pipelines/references/cellranger/refdata-gex-GRCh38-2024-A
localcores: 16
localmem: 120
tool_path: /groups/tprice/software/cellranger
YAML
        ;;

    spaceranger)
        SCRATCH_FASTQ_DIR="$SCRATCH_TEST_DIR/fastq"
        SRC_10X_FASTQ="$TENX_TEST_DATA/spaceranger/fastq"
        SRC_10X_IMAGE="$TENX_TEST_DATA/spaceranger/image.tif"
        SCRATCH_IMAGE="$SCRATCH_TEST_DIR/image.tif"

        if [[ -d "$SRC_10X_FASTQ" ]]; then
            mkdir -p "$SCRATCH_FASTQ_DIR"
            rsync -a "$SRC_10X_FASTQ/" "$SCRATCH_FASTQ_DIR/"
            info "Copied Space Ranger test FASTQs to scratch"
        else
            warn "Test FASTQs not found at $SRC_10X_FASTQ — using placeholder path."
            SCRATCH_FASTQ_DIR="$SRC_10X_FASTQ"
        fi

        if [[ -f "$SRC_10X_IMAGE" ]]; then
            cp "$SRC_10X_IMAGE" "$SCRATCH_IMAGE"
            info "Copied test tissue image to scratch"
        else
            warn "Test image not found at $SRC_10X_IMAGE — using placeholder path."
            SCRATCH_IMAGE="$SRC_10X_IMAGE"
        fi

        cat > "$TEST_CONFIG" <<YAML
sample_id: spaceranger_test
sample_name: spaceranger_test
fastq_dir: $SCRATCH_FASTQ_DIR
transcriptome: /groups/tprice/pipelines/references/cellranger/refdata-gex-GRCh38-2024-A
image: $SCRATCH_IMAGE
slide: V19L29-096
area: B1
localcores: 16
localmem: 120
tool_path: /groups/tprice/software/spaceranger
YAML
        ;;

    xeniumranger)
        SRC_XENIUM_BUNDLE="$TENX_TEST_DATA/xeniumranger/xenium_bundle"
        SCRATCH_BUNDLE="$SCRATCH_TEST_DIR/xenium_bundle"

        if [[ -d "$SRC_XENIUM_BUNDLE" ]]; then
            mkdir -p "$SCRATCH_BUNDLE"
            rsync -a "$SRC_XENIUM_BUNDLE/" "$SCRATCH_BUNDLE/"
            info "Copied Xenium test bundle to scratch"
        else
            warn "Test Xenium bundle not found at $SRC_XENIUM_BUNDLE — using placeholder path."
            SCRATCH_BUNDLE="$SRC_XENIUM_BUNDLE"
        fi

        cat > "$TEST_CONFIG" <<YAML
sample_id: xeniumranger_test
command: resegment
xenium_bundle: $SCRATCH_BUNDLE
localcores: 16
localmem: 120
tool_path: /groups/tprice/software/xeniumranger
YAML
        ;;
esac

info "Generated test config: $TEST_CONFIG"

# ── Delegate to tjp-launch ───────────────────────────────────────────────────
info "Delegating to tjp-launch $PIPELINE --dev --config $TEST_CONFIG"
echo ""
"$SCRIPT_DIR/tjp-launch" "$PIPELINE" --dev --config "$TEST_CONFIG"

# ── Post-launch instructions ─────────────────────────────────────────────────
echo ""
info "After job completes, validate outputs with:"
echo "  tjp-test-validate $PIPELINE"
